# Datagateway — .gitignore

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# SQLite database (regenerated on each fetch)
datagateway.db

# TheRundown API key (gitignored, loaded at runtime)
.therundown_key

# News data (auto-generated from RSS)
# news/

# Dashboard (regenerated on each build)
# Uncomment if you serve from elsewhere:
# dashboard/
